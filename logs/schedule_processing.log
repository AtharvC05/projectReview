<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSMVS Museum Booking</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <nav>
            <a href="#">Home</a> > <a href="#">Museums</a> > <a href="#">Mumbai</a> > <strong>CSMVS</strong>
        </nav>
    </header>
    <main>
        <section class="gallery">
            </section>
        <section class="info">
            <h1>Chhatrapati Shivaji Maharaj Vastu Sangrahalaya</h1>
            <p class="details">
                <span class="rating">4.6 ★★★★★ (35k Reviews)</span> • 
                <span class="status">Open until 6:00 PM</span> • 
                <span>Fort, Mumbai</span>
            </p>
            <button class="primary-cta">Book Tickets</button>
        </section>
        <section class="logistics">
            <div class="address">
                <p><strong>Address:</strong><br>159-161 Mahatma Gandhi Road, Fort, Mumbai, Maharashtra 400023</p>
                <a href="#">Get directions</a>
            </div>
            <div class="timings">
                <p><strong>Timings:</strong></p>
                <p><strong>Mon:</strong> Closed</p>
                <p><strong>Tue - Sun:</strong> 10:15 am - 06:00 pm</p>
            </div>
            <div class="payment">
                <p><strong>Mode of payment:</strong><br>Cash, Debit Card, Credit Card, UPI</p>
            </div>
        </section>
    </main>
</body>
</html>
